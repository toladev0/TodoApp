<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="22dp"
    android:layout_marginTop="28dp"
    android:gravity="center_horizontal">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="46dp"
            android:layout_height="match_parent"
            android:src="@drawable/user_profile_picture"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:fontFamily="@font/lexend_deca"
                android:text="@string/hello"
                android:textSize="14sp"
                android:textColor="@color/black"
                tools:ignore="TextSizeCheck" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:fontFamily="@font/lexend_deca_semibold"
                android:text="@string/livia_vaccaro"
                android:textSize="19sp"
                android:textColor="@color/black"
                tools:ignore="TextSizeCheck" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/notification"
            android:layout_gravity="center_vertical"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="146dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/primary"
        app:cardCornerRadius="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="118dp"
                android:layout_height="102dp"
                android:layout_margin="22dp"
                android:orientation="vertical"
                tools:ignore="TextSizeCheck">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_deca"
                    android:text="@string/today"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:backgroundTint="@color/white"
                    android:fontFamily="@font/lexend_deca_semibold"
                    android:text="@string/view_task"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    app:cornerRadius="9dp"
                    tools:ignore="TouchTargetSizeCheck,TouchTargetSizeCheck,TouchTargetSizeCheck" />

            </LinearLayout>

            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:indeterminateOnly="false"
                    tools:progress="85"
                    android:progress="85"
                    android:layout_gravity="center_horizontal"
                    android:progressDrawable="@drawable/circle">
                </ProgressBar>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/lexend_deca"
                    android:gravity="center"
                    android:text="@string/progress"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    tools:ignore="TextSizeCheck,TextSizeCheck,TextSizeCheck,TextSizeCheck,TextSizeCheck,TextSizeCheck" />

            </RelativeLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_margin="16dp"
                android:src="@drawable/more"
                tools:ignore="ContentDescription,ImageContrastCheck" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_deca_semibold"
            android:text="@string/in_progress"
            android:textColor="@color/black"
            android:textSize="19sp"
            tools:ignore="TextSizeCheck" />

        <RelativeLayout
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:layout_marginStart="6dp"
            tools:ignore="TextSizeCheck">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ellipse"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/lexend_deca"
                android:gravity="center"
                android:text="@string/count_number"
                android:textColor="@color/primary"
                android:textSize="11sp" />

        </RelativeLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:scrollbars="none"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="116dp"
            tools:ignore="VisualLintBounds">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="202dp"
                android:layout_height="116dp"
                android:backgroundTint="#E7F3FF"
                app:cardCornerRadius="19dp"
                tools:ignore="TextSizeCheck">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"
                    android:layout_marginBottom="6dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lexend_deca"
                            android:text="@string/office_project"
                            android:textColor="@color/secondery"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/office_project"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_deca"
                        android:text="@string/grocery_shopping_app_ndesign"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:progress="85"
                        android:progressBackgroundTint="@color/white"
                        android:progressTint="#0087FF"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="202dp"
                android:layout_height="116dp"
                android:backgroundTint="#FFE9E1"
                app:cardCornerRadius="19dp"
                android:layout_marginStart="16dp"
                tools:ignore="TextSizeCheck">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"
                    android:layout_marginBottom="6dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lexend_deca"
                            android:text="@string/personal_project"
                            android:textColor="@color/secondery"
                            android:textSize="11sp"
                            tools:ignore="TextContrastCheck" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/office_project"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_deca"
                        android:text="@string/uber_eats_redesign_nchallange"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:progress="50"
                        android:progressBackgroundTint="@color/white"
                        android:progressTint="#FF7D53" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="16dp"
        android:layout_gravity="start">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexend_deca_semibold"
            android:text="@string/task_groups"
            android:textColor="@color/black"
            android:textSize="19sp"
            tools:ignore="TextSizeCheck" />

        <RelativeLayout
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:layout_marginStart="6dp"
            tools:ignore="TextSizeCheck">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ellipse"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/lexend_deca"
                android:gravity="center"
                android:text="@string/count_number"
                android:textColor="@color/primary"
                android:textSize="11sp" />

        </RelativeLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    
</LinearLayout>